# MongoDB Connection (from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/leadgen?retryWrites=true&w=majority

# Google Sheets
GOOGLE_SHEET_ID=your_sheet_id_from_url
GOOGLE_CREDENTIALS_JSON={"type": "service_account", "project_id": "..."}

# Email (Brevo)
BREVO_API_KEY=xkeysib_xxxxxxxxxxxxx
FROM_EMAIL=your-email@gmail.com
FROM_NAME=Your Name

# Your Info
YOUR_NAME=Your Full Name
YOUR_CAL_LINK=https://cal.com/yourname
YOUR_WEBSITE=https://yourwebsite.com

# Scraper Config
TARGET_CITY=Jaipur
TARGET_BUSINESS=chartered accountants

# Export to Sheets (1 = yes, 0 = no)
EXPORT_TO_SHEETS=1

# Backend Port (for local development)
PORT=5000
